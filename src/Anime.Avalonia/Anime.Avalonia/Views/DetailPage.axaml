<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             x:Class="Anime.Avalonia.Views.DetailPage"
			 xmlns:vm="clr-namespace:Anime.Avalonia.ViewModels"
	         xmlns:entities="clr-namespace:Anime.Infrastructure.Entities;assembly=Anime.Infrastructure"
	         x:DataType="vm:DetailPageViewModel">

	<Grid RowDefinitions="Auto,*,Auto,Auto" Background="#141414" Margin="20">
        <!-- 顶部标题 + 返回 -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <Button Content="← 返回首页" Click="Back_Click" 
                    Background="Transparent" Foreground="#AAA" BorderThickness="0"/>
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Margin="20,0,0,0" 
                       Text="加载中..." Foreground="White"/>
        </StackPanel>

        <!-- 视频播放器 -->
        <Border Grid.Row="1" Background="Black" CornerRadius="12" BoxShadow="0 10 30 #00000080">
            <vlc:VideoView x:Name="VideoView" Height="550" />
        </Border>

        <!-- 线路切换 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,10" Spacing="10">
            <Button x:Name="BtnSrc1" Content="线路一 (主线)" Click="SwitchSource1" 
                    Classes="active-source"/>
            <Button x:Name="BtnSrc2" Content="线路二 (备用)" Click="SwitchSource2"/>
        </StackPanel>

        <!-- 剧集列表 -->
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EpisodesList" ItemsSource="{Binding Episodes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
						<WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="entities:AnimeInfo">
						<Button Content="{Binding Title}"
								Tag="{Binding PlayUrls}"
								Click="PlayEpisode_Click" />
					</DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>