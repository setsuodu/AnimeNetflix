<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MyAvaloniaApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MyAvaloniaApp.Views.MainView"
             x:DataType="vm:MainViewModel"
             FontFamily="avares://Avalonia.Themes.Fluent/Assets/Fonts#Inter,Microsoft YaHei,SimSun,Noto Sans CJK SC">

	<Grid RowDefinitions="Auto,Auto,*" Margin="16">
		<Button Grid.Row="0"
                Content="🚀 开始加载番剧列表"
                Command="{Binding LoadAnimesCommand}"
                HorizontalAlignment="Center"
                Height="70" Width="340"
                FontSize="20"
                Background="#FF4081"
                Foreground="White"
                IsVisible="{Binding !IsLoading}"/>

		<TextBlock Grid.Row="1"
                   Text="{Binding Status}"
                   HorizontalAlignment="Center"
                   FontSize="16"
                   Margin="0,15"
                   Foreground="White"/>

		<ScrollViewer Grid.Row="2" Margin="0,10">
			<ItemsControl ItemsSource="{Binding Animes}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel HorizontalAlignment="Center" ItemWidth="180" Margin="8"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Background="#2D2D2D"
                                CornerRadius="12"
                                Margin="8"
                                Width="170"
                                BoxShadow="0 4 12 0 #1A000000">
							<StackPanel Orientation="Vertical">
								<Border Height="210"
                                        CornerRadius="12,12,0,0"
                                        ClipToBounds="True"
                                        Background="#1C1C1C">
									<Image Source="{Binding CoverUrl}" Stretch="UniformToFill"/>
								</Border>

								<Border Background="#1F1F1F" Padding="8" CornerRadius="0,0,12,12" MinHeight="60">
									<TextBlock Text="{Binding Title}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               FontFamily="Noto Sans CJK SC,DejaVu Sans,sans-serif"/>
								</Border>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>