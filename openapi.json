{
  "openapi": "3.0.4",
  "info": {
    "title": "AnimeNetflix 自宅影院 API",
    "description": "金鹰资源爬虫 + 前端影院接口",
    "contact": {
      "name": "うなみ",
      "url": "https://github.com/setsuodu/AnimeNetflix"
    },
    "version": "v1"
  },
  "paths": {
    "/api/collector/run": {
      "get": {
        "tags": [
          "Collector"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Netflix": {
      "get": {
        "tags": [
          "Netflix"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 30
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Netflix/{id}": {
      "get": {
        "tags": [
          "Netflix"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Netflix/export-for-manus": {
      "get": {
        "tags": [
          "Netflix"
        ],
        "summary": "【临时】“全量导出”接口，找manus拉",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Netflix/export-seed": {
      "get": {
        "tags": [
          "Netflix"
        ],
        "summary": "【常驻】到出 SQL 成 json，迁移备份",
        "description": "调用后会在项目目录生成 seed.json 文件，包含所有动漫信息。\n新部署时 Program.cs 会自动读取这个文件进行 Seed 操作。",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Netflix/import-covers": {
      "post": {
        "tags": [
          "Netflix"
        ],
        "summary": "【临时】manus 爬取的封面导入SQL",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CoverImportDto"
                }
              }
            },
            "text/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CoverImportDto"
                }
              }
            },
            "application/*+json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CoverImportDto"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Netflix/maintenance/flush-jinying": {
      "get": {
        "tags": [
          "Netflix"
        ],
        "summary": "【临时】修复：定义 PlayUrls = 金鹰，BackupUrls = 红牛，没有 m3u8 的补齐",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CoverImportDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "title_JP": {
            "type": "string",
            "nullable": true
          },
          "title_EN": {
            "type": "string",
            "nullable": true
          },
          "coverUrl": {
            "type": "string",
            "nullable": true
          },
          "sourceFingerprint": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Collector"
    },
    {
      "name": "Netflix"
    }
  ]
}